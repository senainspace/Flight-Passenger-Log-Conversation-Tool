<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <!-- ticket_id: 3 uppercase letters + 4 digits (e.g. THY1234) -->
  <xs:simpleType name="TicketIDType">
    <xs:restriction base="xs:string">
      <xs:pattern value="[A-Z]{3}[0-9]{4}"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- app_ver: vX.Y.Z (e.g. v1.0.2) -->
  <xs:simpleType name="AppVerType">
    <xs:restriction base="xs:string">
      <xs:pattern value="v[0-9]+\.[0-9]+\.[0-9]+"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- cabin_class: ECONOMY | BUSINESS | FIRST -->
  <xs:simpleType name="CabinClassType">
    <xs:restriction base="xs:string">
      <xs:enumeration value="ECONOMY"/>
      <xs:enumeration value="BUSINESS"/>
      <xs:enumeration value="FIRST"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- baggage_weight: 0.0 - 50.0 kg -->
  <xs:simpleType name="BaggageWeightType">
    <xs:restriction base="xs:float">
      <xs:minInclusive value="0.0"/>
      <xs:maxInclusive value="50.0"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- loyalty_points: 0 - 10000 -->
  <xs:simpleType name="LoyaltyPointsType">
    <xs:restriction base="xs:integer">
      <xs:minInclusive value="0"/>
      <xs:maxInclusive value="10000"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- seat_num: 1 - 300 -->
  <xs:simpleType name="SeatNumType">
    <xs:restriction base="xs:integer">
      <xs:minInclusive value="1"/>
      <xs:maxInclusive value="300"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- <ticket> element -->
  <xs:complexType name="TicketType">
    <xs:sequence>
      <xs:element name="ticket_id"   type="TicketIDType"/>
      <xs:element name="destination" type="xs:string"/>
      <!-- app_ver uses xs:string to allow records where CSV had no value -->
      <xs:element name="app_ver"     type="xs:string"/>
    </xs:sequence>
  </xs:complexType>

  <!-- <metrics> element -->
  <xs:complexType name="MetricsType">
    <xs:sequence>
      <xs:element name="baggage_weight" type="BaggageWeightType"/>
      <xs:element name="loyalty_points" type="LoyaltyPointsType"/>
      <xs:element name="seat_num"       type="SeatNumType"/>
    </xs:sequence>
    <!-- status holds an emoji (🟢 / 🔴 / ⚠️) as a UTF-8 string -->
    <xs:attribute name="status"      type="xs:string"      use="required"/>
    <xs:attribute name="cabin_class" type="CabinClassType" use="required"/>
  </xs:complexType>

  <!-- <passenger_name> element with encoding metadata attributes -->
  <xs:complexType name="PassengerNameType">
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="current_encoding" type="xs:string" use="required"/>
        <xs:attribute name="first_char_hex"   type="xs:string" use="required"/>
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <!-- <entry id="N"> element -->
  <xs:complexType name="EntryType">
    <xs:sequence>
      <xs:element name="ticket"         type="TicketType"/>
      <xs:element name="metrics"        type="MetricsType"/>
      <xs:element name="timestamp"      type="xs:string"/>
      <xs:element name="passenger_name" type="PassengerNameType"/>
    </xs:sequence>
    <xs:attribute name="id" type="xs:positiveInteger" use="required"/>
  </xs:complexType>

  <!-- Root element name = output filename without extension.
       The Makefile test writes to flightlogs_utf8.xml → root = flightlogs_utf8 -->
  <xs:element name="flightlogs_utf8">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="entry" type="EntryType"
                    minOccurs="1" maxOccurs="unbounded"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

</xs:schema>
